{
  "name": "backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc --noEmit",
    "start": "tsx src/main.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "cd .. && pnpm lint -- backend/src/",
    "migrate": "tsx src/db/migrate.ts",
    "migration:run": "tsx node_modules/typeorm/cli.js migration:run -d src/db/data-source.ts",
    "migration:revert": "tsx node_modules/typeorm/cli.js migration:revert -d src/db/data-source.ts"
  },
  "dependencies": {
    "@mistralai/mistralai": "^1.14.1",
    "@nestjs/common": "^11.1.15",
    "@nestjs/core": "^11.1.15",
    "@nestjs/platform-express": "^11.1.15",
    "@nestjs/typeorm": "^11.0.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.5.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.19.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.15",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.3",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.1.0"
  }
}
